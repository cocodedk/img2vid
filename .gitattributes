# Normalize all text files to LF on commit
* text=auto eol=lf

*.py        text eol=lf
*.sh        text eol=lf
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.md        text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.toml      text eol=lf
*.txt       text eol=lf

# Binary files
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.mp4       binary
*.zip       binary
